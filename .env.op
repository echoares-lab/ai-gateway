# 1Password Secret References for ai-gateway
# Accessed via 1Password Connect at https://{connect-hostname}:8200
# This file is safe to commit (only references, not secrets).

# ── LiteLLM Configuration (prod) ─────────────────────────────────────────────
LITELLM_MASTER_KEY=op://ai-gateway/prod/LITELLM_MASTER_KEY
LITELLM_DATABASE_URL=op://ai-gateway/prod/LITELLM_DATABASE_URL

# ── Database & Cache (prod) ──────────────────────────────────────────────────
REDIS_URL=op://ai-gateway/prod/REDIS_URL

# ── MinIO S3 Storage (prod) ──────────────────────────────────────────────────
MINIO_ROOT_USER=op://ai-gateway/prod/MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=op://ai-gateway/prod/MINIO_ROOT_PASSWORD

# ── CLIProxy API Key (prod) ──────────────────────────────────────────────────
CLIPROXY_API_KEY=op://ai-gateway/prod/CLIPROXY_API_KEY
CLIPROXY_MANAGEMENT_KEY=op://ai-gateway/prod/CLIPROXY_MANAGEMENT_KEY

# ── Langfuse Integration (prod) ──────────────────────────────────────────────
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=op://ai-gateway/prod/LANGFUSE_INIT_PROJECT_PUBLIC_KEY
LANGFUSE_INIT_PROJECT_SECRET_KEY=op://ai-gateway/prod/LANGFUSE_INIT_PROJECT_SECRET_KEY

# ── Model Provider API Keys (prod) ───────────────────────────────────────────
OPENAI_API_KEY=op://ai-gateway/prod/OPENAI_API_KEY
ANTHROPIC_API_KEY=op://ai-gateway/prod/ANTHROPIC_API_KEY
GEMINI_API_KEY=op://ai-gateway/prod/GEMINI_API_KEY

# ── Search & Web Tools (prod) ────────────────────────────────────────────────
BRAVE_API_KEY=op://ai-gateway/prod/BRAVE_API_KEY
SERPER_API_KEY=op://ai-gateway/prod/SERPER_API_KEY
EXA_API_KEY=op://ai-gateway/prod/EXA_API_KEY
