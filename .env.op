# 1Password Secret References for ai-gateway.
# Safe to commit: values are references, not resolved secrets.
# Usage: op run --env-file .env.op -- docker compose up

# Repo runtime: repo-ai-gateway/prod
LITELLM_MASTER_KEY=op://repo-ai-gateway/prod/LITELLM_MASTER_KEY
LITELLM_DATABASE_URL=op://repo-ai-gateway/prod/LITELLM_DATABASE_URL
DATABASE_URL=op://repo-ai-gateway/prod/DATABASE_URL
REDIS_URL=op://repo-ai-gateway/prod/REDIS_URL
REDIS_AUTH=op://repo-ai-gateway/prod/REDIS_AUTH

# Gateway and policy administration
ADMIN_API_KEY=op://repo-ai-gateway/prod/ADMIN_API_KEY
GATEWAY_ENGINE_ADMIN_KEY=op://repo-ai-gateway/prod/GATEWAY_ENGINE_ADMIN_KEY
GATEWAY_ENGINE_URL=op://repo-ai-gateway/prod/GATEWAY_ENGINE_URL
LITELLM_ADMIN_URL=op://repo-ai-gateway/prod/LITELLM_ADMIN_URL
LITELLM_URL=op://repo-ai-gateway/prod/LITELLM_URL
POLICY_ENGINE_URL=op://repo-ai-gateway/prod/POLICY_ENGINE_URL

# CLIProxy
CLIPROXY_API_KEY=op://repo-ai-gateway/prod/CLIPROXY_API_KEY
